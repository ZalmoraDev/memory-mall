{
  "name": "memory-mall",
  "version": "1.0.0",
  "description": "90's themed computer hardware e-commerce platform",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "test": "cross-env APP_STAGE=test vitest run",
    "test:watch": "cross-env APP_STAGE=test vitest",
    "test:coverage": "cross-env APP_STAGE=test vitest run --coverage"
  },
  "author": "ZalmoraDev",
  "dependencies": {
    "express": "^5.1.0",
    "morgan": "^1.10.1",
    "zod": "^4.0.17",
    "drizzle-zod": "^0.8.3",
    "cors": "^2.8.5",
    "jose": "^6.0.12",
    "helmet": "^7.1.0",
    "bcrypt": "^5.1.1",
    "pg": "^8.16.3",
    "drizzle-orm": "^0.44.4",
    "custom-env": "^2.0.6",
    "@epic-web/remember": "^1.1.0"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.10",
    "@types/cors": "^2.8.17",
    "@types/bcrypt": "^5.0.2",
    "@types/supertest": "^6.0.2",
    "@types/node": "^20.11.5",
    "drizzle-kit": "^0.31.4",
    "vitest": "^3.2.4",
    "supertest": "^6.3.4",
    "tsx": "^4.20.4",
    "cross-env": "^10.0.0"
  }
}
